  .shadow-pill.city { background: var(--gold-pale); border-color: var(--gold-light); }
  .shadow-pill.city .city-count { font-size: 10px; color: var(--gold); margin-left: 5px; font-weight: 700; }
  .shadow-pill.icon-pill { display: flex; align-items: center; gap: 6px; padding: 4px 10px 4px 6px; }
  .shadow-kv { display: flex; flex-direction: column; gap: 6px; width: 100%; }
  .shadow-kv-row { display: flex; align-items: flex-start; gap: 8px; font-size: 12.5px; line-height: 1.5; }
  .shadow-kv-label { font-size: 10.5px; font-weight: 700; color: var(--gold); letter-spacing: 0.05em; text-transform: uppercase; flex: 0 0 110px; padding-top: 1px; }
  .shadow-kv-value { color: var(--ink-soft); word-break: break-all; }
  .profile-photo-wrap { text-align: center; }
  .profile-photo-wrap img { width: 52px; height: 52px; border-radius: 50%; border: 2px solid var(--gold-light); object-fit: cover; display: block; }
  .profile-photo-label { font-size: 9px; color: var(--ink-muted); margin-top: 3px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; }
  .location-cards { padding: 16px 24px; display: flex; flex-direction: column; gap: 14px; }
  .location-card { border: 1px solid var(--border); border-radius: 12px; overflow: hidden; page-break-inside: avoid; break-inside: avoid; }
  .location-map { width: 100%; height: 130px; object-fit: cover; display: block; background: var(--cream); }
  .location-body { padding: 12px 14px; }
  .location-meta { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; flex-wrap: wrap; }
  .location-platform { font-size: 10.5px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--gold); }
  .location-date { font-size: 11px; color: var(--ink-muted); }
