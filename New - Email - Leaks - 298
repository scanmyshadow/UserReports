    justify-content: center;
    gap: 8px;
    background: linear-gradient(160deg, #FFD000, #F5A800 50%, #E08C00);
    color: #1A0F00;
    font-size: 13px;
    font-weight: 900;
    padding: 14px 18px;
    border-radius: 999px;
    text-decoration: none;
    letter-spacing: 0.04em;
    box-shadow: 0 4px 18px rgba(245,168,0,0.45), inset 0 1px 0 rgba(255,255,255,0.25);
  }
  .action-btn-secondary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: rgba(255,255,255,0.9);
    border: 1.5px solid rgba(201,154,58,0.45);
    border-radius: 999px;
    padding: 14px 18px;
    font-size: 13px;
    font-weight: 700;
    color: #14151a;
    text-decoration: none;
    box-shadow: 0 2px 10px rgba(201,154,58,0.12);
  }
  @media print { body { background: white; padding: 0; } @page { margin: 24px; } }
</style>
</head>
<body>

<header class="report-header">
  <div class="brand">
    <img src="{{ brand_logo_uri }}" alt="ScanMyShadow" onerror="this.style.background='#F5E6B8';this.style.borderRadius='12px'">
    <div>
      <div class="brand-name">Scan<span>My</span>Shadow</div>
    </div>
  </div>
  <div class="report-meta">
    <div class="report-type">₹298 Privacy Scan — Email Report</div>
    <div class="report-date">{{ report_date }}</div>
  </div>
</header>

<div class="confidential-bar">Confidential &nbsp;·&nbsp; Do not share</div>

<div class="hero">
  <div class="hero-subject">Email Address Scanned</div>
  <div class="hero-phone">{{ email_address }}</div>
  <div class="hero-headline">We searched the entire internet for your email address.<br><strong>Here is what we found.</strong></div>
  {% if breach_count == 0 %}
  <div class="severity-badge low">Low Risk — No Data Breaches Found</div>
  {% elsif breach_count == 1 %}
  <div class="severity-badge medium"><span class="severity-dot"></span>Medium Risk — Attention Recommended</div>
  {% else %}
  <div class="severity-badge high"><span class="severity-dot"></span>High Risk — Immediate Attention Needed</div>
  {% endif %}
  <div class="stat-row">
    <div class="stat-card accent"><div class="stat-number">{{ platform_count }}</div><div class="stat-label">Platforms Found</div></div>
    <div class="stat-card danger"><div class="stat-number">{{ breach_count }}</div><div class="stat-label">Data Breaches</div></div>
    <div class="stat-card"><div class="stat-number">{{ years_of_history }}</div><div class="stat-label">Years of History</div></div>
  </div>
</div>

<!-- SECTION 1: OUR FINDING — full summary shown -->
<div class="narrative-box">
  <div class="narrative-label">Our Finding</div>
  <div class="narrative-text">{{ narrative }}</div>
</div>

<div class="info-note">
  <div class="info-note-icon">ℹ️</div>
  <div class="info-note-body"><strong>A note before you continue.</strong> Not every result is a red flag. Platforms you use daily — Google, Microsoft, LinkedIn — will always appear. Pay attention to <strong>breaches from services you don't recognise or no longer use.</strong> Those are the ones that matter most.</div>
</div>

<!-- SECTION 2: DIGITAL SHADOW — scan stats + key info + names visible, rest locked -->
<div class="shadow-section" style="page-break-before:always;break-before:always;">
  <div class="section-header">
    <div class="section-title-group">
      <div class="section-icon">🪞</div>
      <div>
        <div class="section-title">Your Digital Shadow</div>
        <div class="section-subtitle">Identity data found linked to this email address</div>
      </div>
    </div>
    <div class="section-count">{{ identity_count }} attributes</div>
  </div>

  <div style="padding:12px 24px;background:var(--cream);border-bottom:1px solid var(--border);display:flex;flex-wrap:wrap;gap:6px 20px;">
    <span style="font-size:10px;font-weight:700;letter-spacing:0.09em;text-transform:uppercase;color:var(--gold);flex:0 0 100%;margin-bottom:2px;">Scan Stats</span>
    <span style="font-size:11.5px;color:var(--ink-soft);"><strong style="color:var(--gold);">{{ stats.registered_modules }}</strong> platforms registered</span>
    <span style="font-size:11.5px;color:var(--ink-soft);"><strong style="color:var(--red);">{{ stats.breached_modules }}</strong> breach sources checked</span>
    <span style="font-size:11.5px;color:var(--ink-soft);"><strong style="color:var(--ink);">{{ stats.unique_ids }}</strong> unique IDs</span>
    <span style="font-size:11.5px;color:var(--ink-soft);"><strong style="color:var(--ink);">{{ stats.unique_names }}</strong> name variants</span>
    <span style="font-size:11.5px;color:var(--ink-soft);"><strong style="color:var(--ink);">{{ stats.unique_usernames }}</strong> username variants</span>
    <span style="font-size:11.5px;color:var(--ink-soft);"><strong style="color:var(--ink);">{{ stats.total_locations }}</strong> location events</span>
    <span style="font-size:11.5px;color:var(--ink-soft);"><strong style="color:var(--ink);">{{ stats.unique_cities }}</strong> cities detected</span>
  </div>

  {% if fields.size > 0 %}
  <div class="shadow-strip">
    <div class="shadow-strip-label">Key Info</div>
    <div class="shadow-kv">
      {% for field in fields %}{% unless field.label == "Phone Hint" %}
      <div class="shadow-kv-row"><span class="shadow-kv-label">{{ field.label }}</span><span class="shadow-kv-value">{{ field.value }}</span></div>
      {% endunless %}{% endfor %}
    </div>
  </div>
  {% endif %}

  <div class="shadow-strip">
    <div class="shadow-strip-label">Names Found</div>
    <div class="shadow-pills">{% for name in identity_names %}<div class="shadow-pill">{{ name }}</div>{% endfor %}</div>
  </div>

  <div class="shadow-strip" style="flex-direction:column;gap:8px;">
    <div style="display:flex;align-items:center;gap:10px;"><div class="shadow-strip-label" style="flex:none;">Usernames</div><div style="flex:1;opacity:0.2;"><div style="height:12px;border-radius:4px;background:var(--ink-muted);width:70%;"></div></div></div>
    <div class="lock-card" style="margin-top:0;"><div class="lock-icon">🔒</div><div class="lock-text"><div class="lock-text-title">{{ stats.unique_usernames }} usernames found — locked</div><div class="lock-text-sub">Unlock full scan stats in Deep Dive.</div></div></div>
  </div>

  {% if identity_bios.size > 0 %}
  <div class="shadow-strip" style="flex-direction:column;gap:8px;">
    <div style="display:flex;align-items:center;gap:10px;"><div class="shadow-strip-label" style="flex:none;">Bios Found</div><div style="flex:1;opacity:0.2;"><div style="height:12px;border-radius:4px;background:var(--ink-muted);width:75%;"></div></div></div>
    <div class="lock-card" style="margin-top:0;"><div class="lock-icon">🔒</div><div class="lock-text"><div class="lock-text-title">Bios found — locked</div><div class="lock-text-sub">Unlock full scan stats in Deep Dive.</div></div></div>
  </div>
  {% endif %}

  {% if identity.ids.size > 0 %}
  <div class="shadow-strip" style="flex-direction:column;gap:8px;">
    <div style="display:flex;align-items:center;gap:10px;"><div class="shadow-strip-label" style="flex:none;">Account IDs</div><div style="flex:1;opacity:0.2;"><div style="height:12px;border-radius:4px;background:var(--ink-muted);width:80%;"></div></div></div>
    <div class="lock-card" style="margin-top:0;"><div class="lock-icon">🔒</div><div class="lock-text"><div class="lock-text-title">{{ identity.ids.size }} account IDs found — locked</div><div class="lock-text-sub">Unlock full scan stats in Deep Dive.</div></div></div>
  </div>
  {% endif %}

  <div class="shadow-strip" style="flex-direction:column;gap:8px;">
    <div style="display:flex;align-items:center;gap:10px;"><div class="shadow-strip-label" style="flex:none;">Cities Detected</div><div style="flex:1;opacity:0.2;"><div style="height:12px;border-radius:4px;background:var(--ink-muted);width:55%;"></div></div></div>
    <div class="lock-card" style="margin-top:0;"><div class="lock-icon">🔒</div><div class="lock-text"><div class="lock-text-title">{{ stats.unique_cities }} cities detected — locked</div><div class="lock-text-sub">Unlock full scan stats in Deep Dive.</div></div></div>
  </div>

  {% if phone_hint != "" %}
  <div class="shadow-strip" style="flex-direction:column;gap:8px;">
    <div style="display:flex;align-items:center;gap:10px;"><div class="shadow-strip-label" style="flex:none;">Phone Hint</div><div style="flex:1;opacity:0.2;"><div style="height:12px;border-radius:4px;background:var(--ink-muted);width:45%;"></div></div></div>
    <div class="lock-card" style="margin-top:0;"><div class="lock-icon">🔒</div><div class="lock-text"><div class="lock-text-title">Phone number hint found — locked</div><div class="lock-text-sub">Unlock full scan stats in Deep Dive.</div></div></div>
  </div>
  {% endif %}

  <!-- SECTION 3: Profile Photos — first 6, lock rest -->
  {% if profile_images.size > 0 %}
  <div class="shadow-strip">
    <div class="shadow-strip-label">Profile Photos</div>
    <div style="display:flex;flex-wrap:wrap;gap:12px;align-items:flex-start;width:100%;">
      {% for img in profile_images %}{% if forloop.index <= 6 %}
      <div class="profile-photo-wrap">
        <img src="{{ img.image_url }}" alt="{{ img.platform }}" onerror="this.parentElement.style.display='none'">
        <div class="profile-photo-label">{{ img.platform }}</div>
      </div>
      {% endif %}{% endfor %}
      {% if profile_images.size > 6 %}
      <div class="lock-card" style="width:100%;margin-top:4px;">
        <div class="lock-icon">🔒</div>
        <div class="lock-text"><div class="lock-text-title">+{{ profile_images.size | minus: 6 }} more photos found</div><div class="lock-text-sub">All profile photos available in Deep Dive.</div></div>
        <div class="lock-count-badge">Deep Dive only</div>
      </div>
      {% endif %}
    </div>
  </div>
  {% endif %}

  <!-- SECTION 4: Also On — full, no lock -->
  {% if also_registered.size > 0 %}
  <div class="shadow-strip" style="page-break-inside:avoid;break-inside:avoid;">
    <div class="shadow-strip-label">Also On</div>
    <div style="display:flex;flex-wrap:wrap;gap:7px;">
      {% for item in also_registered %}
      <div class="shadow-pill icon-pill">
        <img src="{{ item.logo_uri }}" alt="{{ item.name }}" style="width:16px;height:16px;object-fit:contain;">
        {{ item.name }}
      </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  <!-- SECTION 5: Locations — first 2, lock rest -->
  {% if locations.size > 0 %}
  <div class="location-cards">
    {% for loc in locations %}{% if forloop.index <= 2 %}
    <div class="location-card">
      {% if loc.map_url != "" %}<img class="location-map" src="{{ loc.map_url }}" alt="Map" onerror="this.style.display='none'">{% endif %}
      <div class="location-body">
        <div class="location-meta">
          <span class="location-platform">{{ loc.platform }}</span>
          <span class="location-dot"></span>
          <span class="location-date">{{ loc.date }}</span>
          {% if loc.city != "" %}<span class="location-dot"></span><span style="font-size:11px;color:var(--ink-muted);">{{ loc.city }}, {{ loc.country }}</span>{% endif %}
        </div>
        {% if loc.subtitle != "" %}<div class="location-place">📍 {{ loc.subtitle }}</div>{% endif %}
        <div class="location-address">{{ loc.address }}</div>
        {% if loc.lat != "" %}<div class="location-coords">{{ loc.lat }}, {{ loc.lng }}</div>{% endif %}
        {% if loc.comment != "" %}<div class="location-review">"{{ loc.comment }}"</div>{% endif %}
      </div>
    </div>
    {% endif %}{% endfor %}
    {% if locations.size > 2 %}
    <div class="lock-card">
      <div class="lock-icon">🔒</div>
      <div class="lock-text"><div class="lock-text-title">{{ locations.size | minus: 2 }} more locations found</div><div class="lock-text-sub">Every location event, address, and map pin is available in Deep Dive.</div></div>
      <div class="lock-count-badge">Deep Dive only</div>
    </div>
    {% endif %}
  </div>
  {% endif %}
</div>

<!-- SECTION 6: WHERE YOUR EMAIL WAS FOUND — first 2 + lock detail grid, lock rest -->
<div class="section" style="page-break-before:always;break-before:always;">
  <div class="section-header">
    <div class="section-title-group">
      <div class="section-icon">📧</div>
      <div>
        <div class="section-title">Where Your Email Was Found</div>
        <div class="section-subtitle">Apps and websites that have your email address</div>
      </div>
    </div>
    <div class="section-count">{{ platform_count }} found</div>
  </div>
  <div class="section-body">
    {% for platform in platforms %}{% if forloop.index <= 2 %}
    <div class="platform-row">
      <div class="platform-icon">
        <img src="{{ platform.logo_uri }}" alt="{{ platform.name }}" width="26" height="26" style="object-fit:contain;border-radius:3px;" onerror="this.style.display='none'">
      </div>
      <div class="platform-name">{{ platform.name }}</div>
      <div class="platform-detail-wrap">
        <div class="platform-summary">
          {% for field in platform.fields %}{% if forloop.index <= 4 %}<span class="evidence-chip"><strong>{{ field.label }}</strong>{{ field.value }}</span>{% endif %}{% endfor %}
        </div>
        <div style="position:relative;">
          <div style="opacity:0.15;">
            <div class="platform-evidence">
              {% for field in platform.fields %}<div class="evidence-row"><span class="evidence-label">{{ field.label }}</span><span class="evidence-value">{{ field.value }}</span></div>{% endfor %}
            </div>
          </div>
          <div style="position:absolute;top:0;left:0;right:0;bottom:0;display:flex;align-items:center;justify-content:center;">
            <div style="background:var(--gold-pale);border:1px solid var(--gold-light);border-radius:8px;padding:6px 14px;font-size:11px;font-weight:700;color:var(--gold);display:flex;align-items:center;gap:6px;">🔒 Full details in Deep Dive</div>
          </div>
        </div>
      </div>
    </div>
    {% endif %}{% endfor %}
    {% if platform_count > 2 %}
    <div class="lock-card" style="margin-top:12px;">
      <div class="lock-icon">🔒</div>
      <div class="lock-text"><div class="lock-text-title">{{ platform_count | minus: 2 }} more platforms locked</div><div class="lock-text-sub">Every platform, profile detail, and linked account is in your full report — available in Deep Dive.</div></div>
      <div class="lock-count-badge">+{{ platform_count | minus: 2 }} more</div>
    </div>
    {% endif %}
  </div>
</div>

<!-- SECTION 7: DATA BREACHES — first 2 + lock data tags, lock rest, varied statements -->
<div class="section" style="page-break-before:always;break-before:always;">
  <div class="section-header">
    <div class="section-title-group">
      <div class="section-icon">⚠️</div>
      <div>
        <div class="section-title">Data Breaches</div>
        <div class="section-subtitle">Your data was leaked in these incidents</div>
      </div>
    </div>
    <div class="section-count danger">{{ breach_count }} found</div>
  </div>
  <div class="section-body">
    {% for breach in breaches %}{% if forloop.index <= 2 %}
    <div class="breach-row">
      <div class="breach-sev {{ breach.severity }}" style="margin-top:14px;"></div>
      <div style="display:flex;align-items:flex-start;gap:10px;">
        <div style="width:32px;height:32px;border-radius:8px;border:1px solid var(--border);background:var(--white);display:flex;align-items:center;justify-content:center;flex-shrink:0;overflow:hidden;"><img src="{{ breach.logo_uri }}" alt="{{ breach.name }}" style="width:20px;height:20px;object-fit:contain;" onerror="this.style.display='none'"></div>
        <div>
          <div class="breach-name">{{ breach.name }}</div>
          <div class="breach-meta">
            <span>{{ breach.date }}</span>
            <span>{{ breach.records }} records</span>
            <span class="breach-sev-badge {{ breach.severity }}">{% if breach.severity == "high" %}High Risk{% elsif breach.severity == "medium" %}Medium Risk{% else %}Low Risk{% endif %}</span>
          </div>
        </div>
      </div>
      <div class="breach-content">
        {% assign breach_mod = forloop.index0 | modulo: 4 %}
        {% if breach_mod == 0 %}<div class="breach-description">Your data was part of this incident. What was exposed is only visible in Deep Dive.{% if breach.website != "" %} <span style="color:var(--ink-muted);">Source: {{ breach.website }}</span>{% endif %}</div>
        {% elsif breach_mod == 1 %}<div class="breach-description">This breach touched your account. The specifics — what leaked and when — are in your Deep Dive report.{% if breach.website != "" %} <span style="color:var(--ink-muted);">Source: {{ breach.website }}</span>{% endif %}</div>
        {% elsif breach_mod == 2 %}<div class="breach-description">Records from this incident include your information. Full details available in Deep Dive.{% if breach.website != "" %} <span style="color:var(--ink-muted);">Source: {{ breach.website }}</span>{% endif %}</div>
        {% else %}<div class="breach-description">Your email appeared in this data leak. To see exactly what was exposed, unlock your Deep Dive report.{% if breach.website != "" %} <span style="color:var(--ink-muted);">Source: {{ breach.website }}</span>{% endif %}</div>
        {% endif %}
        <div style="position:relative;margin-top:4px;">
          <div style="opacity:0.15;"><div class="breach-data-list">{% for bd in breach.breached_data %}<span>{{ bd }}</span>{% endfor %}</div></div>
          <div style="position:absolute;top:0;left:0;right:0;bottom:0;display:flex;align-items:center;">
            <div style="background:var(--red-pale);border:1px solid rgba(192,57,43,0.20);border-radius:6px;padding:4px 12px;font-size:11px;font-weight:700;color:var(--red);display:flex;align-items:center;gap:6px;">🔒 Exposed data types locked</div>
          </div>
        </div>
      </div>
    </div>
    {% endif %}{% endfor %}
    {% if breach_count > 2 %}
    <div class="lock-card" style="margin-top:12px;">
      <div class="lock-icon">🔒</div>
      <div class="lock-text"><div class="lock-text-title">{{ breach_count | minus: 2 }} more breaches locked</div><div class="lock-text-sub">The full list of incidents, what was exposed in each, and how to respond — all in Deep Dive.</div></div>
      <div class="lock-count-badge">+{{ breach_count | minus: 2 }} more</div>
    </div>
    {% endif %}
    {% if breach_count == 0 %}
    <div style="padding:16px 0 6px;text-align:center;">
      <div style="font-size:13px;color:var(--green);font-weight:700;margin-bottom:4px;">✓ No breaches found on record</div>
      <div style="font-size:12px;color:var(--ink-muted);line-height:1.6;">Your email was not found in any known data breach databases. Breaches can take months to surface, so a clean result today does not guarantee one tomorrow.</div>
    </div>
    {% endif %}
  </div>
</div>

<!-- SECTION 8: DIGITAL TIMELINE — full chart + top 5, lock rest -->
<div class="timeline-section" style="page-break-before:always;break-before:always;">
  <div class="section-header">
    <div class="section-title-group">
      <div class="section-icon">🕐</div>
      <div>
        <div class="section-title">Your Digital Timeline</div>
        <div class="section-subtitle">A history of where your email data has appeared</div>
      </div>
    </div>
  </div>
  <div class="timeline-headline-box">
    <div class="timeline-headline-number">{{ years_of_history }} years</div>
    <div class="timeline-headline-text">Your email address has been active online since <strong>{{ earliest_year }}</strong> — that is {{ total_events }} events we tracked across different platforms.</div>
  </div>
  {% if year_groups.size > 0 %}
  <div style="padding:16px 24px 0;">
    <div style="font-size:10px;font-weight:700;letter-spacing:0.09em;text-transform:uppercase;color:var(--gold);margin-bottom:10px;">Activity by Year</div>
    {% assign max_count = 1 %}
    {% for yg in year_groups %}{% if yg.count > max_count %}{% assign max_count = yg.count %}{% endif %}{% endfor %}
    <div style="display:flex;align-items:flex-end;gap:6px;height:64px;">
      {% for yg in year_groups %}
      {% assign bar_pct = yg.count | times: 100 | divided_by: max_count %}
      <div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:2px;">
        <div style="font-size:8.5px;color:var(--ink-muted);font-weight:600;">{{ yg.count }}</div>
        <div style="width:100%;background:var(--gold-bright);border-radius:3px 3px 0 0;height:{{ bar_pct | times: 44 | divided_by: 100 | plus: 4 }}px;min-height:4px;"></div>
        <div style="font-size:8px;color:var(--ink-muted);font-weight:500;writing-mode:vertical-rl;transform:rotate(180deg);height:26px;line-height:1;">{{ yg.year }}</div>
      </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}
  <div style="padding:16px 24px;">
    {% for event in events %}{% if forloop.index <= 5 %}
    <div class="timeline-fake-row">
      <div class="tl-date">{{ event.date }}</div>
      <div class="tl-source">{{ event.source }}</div>
      <div class="tl-content">{{ event.content }}</div>
    </div>
    {% endif %}{% endfor %}
    {% if total_events > 5 %}
    <div class="lock-card" style="margin-top:12px;">
      <div class="lock-icon">🔒</div>
      <div class="lock-text"><div class="lock-text-title">{{ total_events | minus: 5 }} more timeline entries locked</div><div class="lock-text-sub">The complete history of every event linked to your email — available in Deep Dive.</div></div>
      <div class="lock-count-badge">+{{ total_events | minus: 5 }} more</div>
    </div>
    {% endif %}
  </div>
</div>

<div class="gold-divider"></div>

<!-- SECTION 9: SOURCES CHECKED — full, nothing hidden -->
<div class="section" style="margin-bottom:20px;page-break-before:always;break-before:always;">
  <div class="section-header">
    <div class="section-title-group">
      <div class="section-icon">🔍</div>
      <div>
        <div class="section-title">Sources Checked</div>
        <div class="section-subtitle">Every database and platform we scanned</div>
      </div>
    </div>
  </div>
  <div class="section-body">
    <div style="display:flex;flex-wrap:wrap;gap:7px;align-items:center;">
      {% for src in sources_with_logos %}
      <div class="source-chip">
        {% if src.locked %}<span style="font-size:12px;">🔓</span>{% else %}<img src="{{ src.logo_uri }}" alt="{{ src.name }}" style="width:18px;height:18px;object-fit:contain;">{% endif %}
        <span class="source-chip-name">{{ src.name }}</span>
      </div>
      {% endfor %}
      <div style="font-size:11.5px;color:var(--ink-muted);font-style:italic;padding:5px 4px;">+ many more</div>
    </div>
  </div>
</div>

<div class="gold-divider"></div>

<!-- REMOVAL TOOLKIT — compact lock card -->
<div class="guide-section" style="page-break-before:always;break-before:always;">
  <div class="guide-section-header" style="page-break-after:avoid;break-after:avoid;">
    <div class="guide-section-title">Your Personalised Removal Toolkit</div>
    <div class="guide-section-sub">Step-by-step actions specific to your scan results.</div>
  </div>
  <div style="background:rgba(184,134,11,0.06);border:1px solid rgba(184,134,11,0.22);border-radius:10px;padding:16px 18px;display:flex;gap:12px;align-items:flex-start;">
    <span style="font-size:18px;flex-shrink:0;">🔒</span>
