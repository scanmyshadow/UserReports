  .platform-icon img { width: 26px; height: 26px; object-fit: contain; display: block; }
  .platform-name { font-size: 14px; font-weight: 700; color: var(--ink); padding-top: 8px; }
  .platform-detail-wrap { flex: 1; position: relative; }
