  .hero { background: var(--white); border: 1px solid var(--border); border-top: 3px solid var(--gold-bright); border-radius: 16px; padding: 36px 32px 32px; margin-bottom: 24px; box-shadow: var(--shadow-md); text-align: center; }
  .hero-subject { font-size: 13px; font-weight: 700; color: var(--gold); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 6px; }
  .hero-phone { font-family: 'DM Sans', sans-serif; font-size: 28px; font-weight: 700; color: var(--ink); margin-bottom: 8px; letter-spacing: -0.02em; }
  .hero-headline { font-size: 15px; color: var(--ink-soft); max-width: 520px; margin: 0 auto 24px; line-height: 1.65; }
