  .location-address { font-size: 12px; color: var(--ink-soft); margin-bottom: 6px; }
  .location-coords { font-size: 10.5px; color: var(--ink-muted); margin-bottom: 6px; }
  .location-review { background: var(--cream); border-radius: 6px; padding: 8px 10px; font-size: 12px; color: var(--ink-soft); font-style: italic; line-height: 1.55; border-left: 3px solid var(--gold-light); margin-top: 6px; }
  .info-note { background: #F4F6FF; border: 1px solid rgba(70,90,200,0.14); border-radius: 10px; padding: 14px 18px; margin-bottom: 24px; display: flex; gap: 12px; align-items: flex-start; }
  .info-note-icon { font-size: 15px; flex-shrink: 0; margin-top: 1px; }
